# ============================================================
# VenturePilot AI — Environment Variables
# Copy this to .env and fill in your keys.
# ============================================================

# --- Google Gemini (FREE - get at https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=AIza...

# --- GitHub API (FREE - https://github.com/settings/tokens) ---
GITHUB_TOKEN=ghp_...

# --- NewsAPI (FREE 100 req/day - https://newsapi.org/register) ---
NEWSAPI_KEY=

# --- Google Custom Search (FREE 100 req/day) ---
# 1. Create a search engine: https://programmablesearchengine.google.com/
#    - Under "Sites to search", choose "Search the entire web"
# 2. Get your Search engine ID (cx) from the Setup page
# 3. Get API key: https://console.cloud.google.com/apis/credentials
# NOTE: The Gemini API key above works here too if Gemini API is enabled in your GCP project
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# --- App ---
APP_PORT=8000
VITE_API_BASE_URL=http://localhost:8000
