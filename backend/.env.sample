# =============================================================================
# XL Ventures AI - Investment Analysis Platform
# Environment Configuration (GCP Edition)
# =============================================================================

# --- API server ---
PROJECT_NAME="XL Ventures - Investment Analysis Platform"
VERSION="1.0.0"
DEBUG=True
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8084
ALLOW_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- Google Cloud Platform ---
# Set your GCP Project ID to enable live Firestore, GCS and Vertex AI.
# Leave blank to run fully offline with local JSON file mocks.
GCP_PROJECT_ID=
GCP_LOCATION=us-central1

# --- Cloud Firestore ---
FIRESTORE_DATABASE_ID=(default)

# --- Google Cloud Storage ---
# Set your GCS bucket name (created separately in your GCP project).
# Leave blank to store uploaded files locally in ./local_storage/
GCS_BUCKET_NAME=

# --- Vertex AI / Gemini ---
GEMINI_MODEL_NAME=gemini-1.5-pro